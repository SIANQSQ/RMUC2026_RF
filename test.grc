- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nimport serial\nfrom gnuradio import gr\n\n\
      class blk(gr.sync_block):\n    def __init__(self, port='/dev/ttyUSB0', baudrate=9600):\n\
      \        gr.sync_block.__init__(self, name='REFEREE Output', in_sig=[], out_sig=[np.uint8])\n\
      \        self.ser = serial.Serial(port, baudrate, timeout=1)\n\n    def work(self,\
      \ input_items, output_items):\n        if self.ser.in_waiting > 0:\n       \
      \     data = self.ser.read(self.ser.in_waiting)\n            data_array = np.frombuffer(data,\
      \ dtype=np.uint8)\n            n_items = min(len(data_array), len(output_items[0]))\n\
      \            output_items[0][:n_items] = data_array[:n_items]\n            return\
      \ n_items\n        return 0\n"
    affinity: ''
    alias: ''
    baudrate: '921600'
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    port: '''/dev/ttyUSB0'''
  states:
    _io_cache: ('REFEREE Output', 'blk', [('port', "'/dev/ttyUSB0'"), ('baudrate',
      '9600')], [], [('0', 'byte', 1)], '', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [32, 812.0]
    rotation: 0
    state: true
